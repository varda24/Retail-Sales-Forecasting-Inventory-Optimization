    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "dates = pd.date_range(start='2023-01-01', periods=200)\n",
    "\n",
    "sales = np.random.randint(50, 200, size=len(dates))\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    \"Date\": dates,\n",
    "    \"Sales\": sales\n",
    "})\n",
    "\n",
    "df.to_csv(\"data/raw/retail_data.csv\", index=False)"
   ]
